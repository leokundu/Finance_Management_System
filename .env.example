# Supabase API (not used for the DB connection itself, kept for any future
# use of Supabase Auth/Storage/REST - the app currently only needs DATABASE_URL below)
SUPABASE_URL=https://rnhphksualvsprnjxcmy.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_JWKS_URL=https://rnhphksualvsprnjxcmy.supabase.co/auth/v1/.well-known/jwks.json

# REQUIRED: direct Postgres connection string (SQLAlchemy needs this, not
# the API keys above). Get it from Supabase -> Project Settings -> Database
# -> Connection string -> URI, and fill in your actual DB password.
DATABASE_URL=postgresql://postgres:YOUR-DB-PASSWORD@db.rnhphksualvsprnjxcmy.supabase.co:5432/postgres
